# Anthropic - get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI - used only for embeddings (text-embedding-3-small)
# get from platform.openai.com
OPENAI_API_KEY=sk-...

# Supabase - get from supabase.com dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cohere - used for re-ranking, get from cohere.com
# free tier is fine for personal use
COHERE_API_KEY=your-cohere-key

# How many chunks to retrieve per query before re-ranking
RETRIEVAL_TOP_K=20

# How many chunks to send to Claude after re-ranking
RERANK_TOP_K=8

# Relevance threshold for the hybrid agent (0.0–1.0)
# Fathers whose top rerank score falls below this are excluded from the response
# 0.3 = permissive (more Fathers respond), 0.6 = strict (only highly relevant Fathers)
RELEVANCE_THRESHOLD=0.3
